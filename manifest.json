{
  "manifest_version": 1,
  "name": "hermes-feishu-zh",
  "version": "0.2.3",
  "description": "Hermes Agent 飞书中文化包。114 条中文化规则，覆盖飞书消息、Webhook 错误、CLI 输出、评论系统、媒体失败提示等。",
  "license": "MIT",
  "homepage": "https://github.com/OLDBAI213/hermes-feishu-zh",
  "status": "compatible_on_local_hermes_0.15.1",
  "target": {
    "product": "Hermes Agent",
    "version_range": ">=0.14.0",
    "platforms": [
      "windows"
    ]
  },
  "profiles": {
    "stable": {
      "default": true,
      "description": "合并中文化配置、安装 lark-cli 工具箱、使用飞书 post 输出格式、应用中文化和基础适配规则。"
    },
    "enhanced": {
      "default": false,
      "description": "在稳定版基础上，增加可选的交互式卡片输出和增强飞书显示源码补丁；发布前必须重新跑 verify。"
    }
  },
  "entrypoints": {
    "install": "install.ps1",
    "verify": "verify.ps1",
    "rollback": "install.ps1 -Rollback latest",
    "uninstall": "install.ps1 -Uninstall"
  },
  "modifies": {
    "config": [
      "config.yaml"
    ],
    "plugins": [
      "plugins/lark-cli-toolbox"
    ],
    "source_optional": [
      "hermes-agent/gateway/platforms/feishu.py",
      "hermes-agent/gateway/platforms/feishu_comment.py",
      "hermes-agent/gateway/platforms/feishu_comment_rules.py",
      "hermes-agent/gateway/run.py",
      "hermes-agent/tools/send_message_tool.py"
    ],
    "audit_assets": [
      "hermes-agent/scripts/feishu_localization_audit.py",
      "hermes-agent/locales/feishu_zh_audit_allowlist.yaml"
    ]
  },
  "backup": {
    "directory": "backups/hermes-feishu-zh-<timestamp>",
    "files": [
      "config.yaml",
      ".env",
      "plugins/lark-cli-toolbox",
      "patched source files"
    ]
  },
  "verify": {
    "command": "powershell -ExecutionPolicy Bypass -File .\\verify.ps1",
    "checks": [
      "Hermes CLI resolves",
      "display.language == zh",
      "display.gateway_locale == zh",
      "Feishu outbound_format/card_mode routes text, post, and interactive payloads correctly",
      "lark-cli-toolbox plugin loads",
      "lark_cli tools are registered",
      "Feishu source Chinese labels and compact mobile markers are present",
      "Feishu user-visible English localization audit has zero unapproved items",
      "MEDIA path parsing keeps attachments out of message text",
      "lark-cli doctor passes when installed",
      "gateway_state is running and feishu is connected when gateway is enabled"
    ]
  },
  "does_not_contain": [
    "FEISHU_APP_ID",
    "FEISHU_APP_SECRET",
    "FEISHU_ALLOWED_USERS",
    "XIAOMI_API_KEY",
    "API keys",
    "tokens"
  ]
}
