{
  "manifest_version": 1,
  "name": "hermes-feishu",
  "version": "1.0.0",
  "description": "Hermes Agent 飞书全套件。中文化、显示增强、媒体适配、工具进度、结构化输出，一键安装。",
  "license": "MIT",
  "homepage": "https://github.com/OLDBAI213/hermes-feishu-zh",
  "target": {
    "product": "Hermes Agent",
    "version_range": ">=0.14.0",
    "platforms": [
      "windows"
    ]
  },
  "modules": {
    "zh": {
      "description": "中文化核心 — 114 条规则，覆盖飞书消息、Webhook 错误、CLI 输出、评论系统",
      "patches": [
        "patches/stable.config.yaml",
        "patches/feishu-card-zh.replacements.json"
      ]
    },
    "display": {
      "description": "显示增强 — 工具调用记录、三状态显示、结构化正文、移动端可读性",
      "depends_on": ["zh"],
      "patches": [
        "patches/feishu-display-upgrade.replacements.json",
        "patches/display-plus/source.replacements.json",
        "patches/display-plus/stable.config.yaml"
      ]
    },
    "adapter": {
      "description": "媒体适配 — 图片/文件/音视频/混合消息/队列/下载失败诊断",
      "patches": [
        "patches/adapter/source.replacements.json"
      ]
    }
  },
  "profiles": {
    "stable": {
      "default": true,
      "modules": ["zh", "adapter"],
      "description": "中文化 + 媒体适配，适合大多数用户。"
    },
    "full": {
      "default": false,
      "modules": ["zh", "display", "adapter"],
      "description": "全功能 — 中文化 + 显示增强 + 媒体适配。"
    }
  },
  "entrypoints": {
    "install": "install.ps1",
    "verify": "verify.ps1",
    "rollback": "install.ps1 -Rollback latest",
    "uninstall": "install.ps1 -Uninstall"
  },
  "modifies": {
    "config": [
      "config.yaml"
    ],
    "plugins": [
      "plugins/lark-cli-toolbox"
    ],
    "source_optional": [
      "hermes-agent/gateway/platforms/feishu.py",
      "hermes-agent/gateway/platforms/feishu_comment.py",
      "hermes-agent/gateway/platforms/feishu_comment_rules.py",
      "hermes-agent/gateway/run.py",
      "hermes-agent/tools/send_message_tool.py",
      "hermes-agent/run_agent.py",
      "hermes-agent/agent/image_routing.py"
    ]
  },
  "backup": {
    "directory": "backups/hermes-feishu-<timestamp>",
    "files": [
      "config.yaml",
      ".env",
      "plugins/lark-cli-toolbox",
      "patched source files"
    ]
  },
  "verify": {
    "command": "powershell -ExecutionPolicy Bypass -File .\\verify.ps1",
    "checks": [
      "Hermes CLI resolves",
      "display.language == zh",
      "display.gateway_locale == zh",
      "Feishu outbound_format is post or card",
      "lark-cli-toolbox plugin loads",
      "lark_cli tools are registered",
      "Feishu source Chinese labels and compact mobile markers are present",
      "MEDIA path parsing keeps attachments out of message text",
      "lark-cli doctor passes when installed",
      "gateway_state is running and feishu is connected when gateway is enabled"
    ]
  },
  "does_not_contain": [
    "FEISHU_APP_ID",
    "FEISHU_APP_SECRET",
    "FEISHU_ALLOWED_USERS",
    "XIAOMI_API_KEY",
    "API keys",
    "tokens"
  ]
}
